# Competitor Matcher Environment Variables
# Copy this file to .env and fill in your API keys

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REQUIRED: OpenRouter API Key for AI Agent
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Model to use (default: anthropic/claude-sonnet-4)
# Options: anthropic/claude-sonnet-4, anthropic/claude-3-haiku, etc.
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL: Brave Search API Key (for web search fallback)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Only needed if local data is empty and you want web search fallback
# Get your key at: https://brave.com/search/api/
BRAVE_API_KEY=
